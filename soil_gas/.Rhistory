tidy_one_lme <- function(fit, resp) {
## 4.1 Fixed effect -------------------------------------------------
fixed_raw <- broom.mixed::tidy(fit) %>% filter(term != "(Intercept)")
if (!"std.error" %in% names(fixed_raw)) fixed_raw <- fixed_raw %>% mutate(std.error = NA_real_)
if (!"statistic" %in% names(fixed_raw)) fixed_raw <- fixed_raw %>% mutate(statistic = NA_real_)
fixed_tbl <- fixed_raw %>%
dplyr::rename(
Estimate   = estimate,
Std_Error  = std.error,
t_value    = statistic,
p_value    = p.value
) %>%
mutate(Response = resp,
Term     = term,
Model    = "Fixed effect") %>%
select(Response, Term, Model, Estimate, Std_Error, t_value, p_value)
## 4.2 Confidence intervals -----------------------------------------
ci_mat <- intervals(fit, which = "fixed", level = 0.95)$fixed
ci_fixed <- as.data.frame(ci_mat) %>%
rownames_to_column("term") %>%
dplyr::rename(CI_lower = lower, CI_upper = upper) %>%
mutate(term = gsub("^.*~", "", term))
fixed_tbl <- left_join(fixed_tbl, ci_fixed, by = c("Term" = "term"))
## 4.3 Random effect -------------------------------------------------
ran_raw <- broom.mixed::tidy(fit, effects = "ran_vals")
if (!"std.error" %in% names(ran_raw)) ran_raw <- ran_raw %>% mutate(std.error = NA_real_)
if (!"statistic" %in% names(ran_raw)) ran_raw <- ran_raw %>% mutate(statistic = NA_real_)
ran_tbl <- ran_raw %>%
mutate(Response = resp,
Term     = "Random intercept (plot_no)",
Model    = "Random effect",
Estimate = estimate,
Std_Error = std.error,
t_value   = statistic,
p_value   = NA_real_,
CI_lower  = NA_real_,
CI_upper  = NA_real_) %>%
select(Response, Term, Model, Estimate, Std_Error,
t_value, p_value, CI_lower, CI_upper)
## 4.4 Model‑fit statistics -----------------------------------------
fit_stats <- broom.mixed::glance(fit) %>%
mutate(REMLcrit = ifelse("REMLcrit" %in% names(.), REMLcrit, NA_real_),
Response = resp,
Term     = "Model fit",
Model    = "Fit statistics",
Estimate = NA_real_, Std_Error = NA_real_,
t_value = NA_real_, p_value = NA_real_,
CI_lower = NA_real_, CI_upper = NA_real_,
AIC = AIC, BIC = BIC, LogLik = logLik) %>%
select(Response, Term, Model, Estimate, Std_Error,
t_value, p_value, CI_lower, CI_upper,
AIC, BIC, LogLik, REMLcrit)
## 4.5 Bind everything ------------------------------------------------
bind_rows(fixed_tbl, ran_tbl, fit_stats)
}
